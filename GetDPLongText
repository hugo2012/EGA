@78\QImporting@	IV_GUID	TYPE RPM_TV_GUID	Guid for application objects
@78\QImporting@	IV_LANGU	TYPE SYLANGU	Language Key
@79\QExporting@	ET_LINE	TYPE ZPPM_WF_LTXT_TT	WF Long Text
@79\QExporting@	EV_SH_TEXT	TYPE AD_SMTPADR	E-Mail Address


METHOD get_long_text.
    CONSTANTS: lc_end_of_note     TYPE char15 VALUE '%EOF_NOTE%',
               lc_horizontal_line TYPE c LENGTH 70 VALUE '______________________________________________________________________'.


    " get long text details from standard RPM enttity services
    DATA lt_lines TYPE text_line_tab.
    DATA lv_string TYPE string.
    DATA lv_timestamp_char   TYPE /rpm/tv_string.
    DATA lv_creator          TYPE /rpm/tv_string.
    DATA lv_offset           TYPE i.
    DATA lv_length           TYPE i.
    DATA lv_text             TYPE /rpm/tv_string.
    DATA lv_comment                      TYPE string.
    DATA lt_note             TYPE TABLE OF string.
    DATA lt_note_ext         TYPE TABLE OF string.
    DATA ls_separator        TYPE string.
    DATA ls_comment_ext      TYPE /rpm/ts_note_ext.
    DATA lv_comment_header   TYPE char255.
    DATA lv_timezone         TYPE timezone.
    DATA lr_user             TYPE REF TO cl_aco_user.
    DATA lv_user_attributes  TYPE aco_user_attributes.
    DATA lv_timestamp        TYPE timestamp.
    DATA lt_tline TYPE TABLE OF tline.

    CALL METHOD cl_rpm_entity_services=>get_long_text_rpm
      EXPORTING
        iv_guid          = iv_guid
        iv_language      = iv_langu
*       iv_format        = '  '
      IMPORTING
        et_lines         = lt_lines
        ev_string        = lv_comment
      EXCEPTIONS
        invalid_language = 1
        invalid_text_id  = 2
        not_found        = 3
        OTHERS           = 4.
    IF sy-subrc EQ 0 .
*      LOOP AT lt_lines INTO DATA(ls_lines).
      CONCATENATE   cl_abap_char_utilities=>newline
                     cl_abap_char_utilities=>newline
                     lc_horizontal_line
                     cl_abap_char_utilities=>newline
                     INTO ls_separator.

* get single comments  as table
      SPLIT lv_comment AT ls_separator INTO TABLE lt_note.
      LOOP AT lt_note INTO DATA(lv_note).

        CLEAR: lv_user_attributes,
               lv_comment_header.

        DATA(lv_pattern) = /rpm/cl_co=>sc_note_timestamp.
        FIND lv_pattern IN lv_note RESULTS DATA(ls_match_timestamp).

        lv_pattern = cl_dpr_co=>sc_note_creator.
        FIND lv_pattern IN lv_note RESULTS DATA(ls_match_creator).

        lv_pattern = cl_dpr_co=>sc_note_changeable.
        FIND lv_pattern IN lv_note RESULTS DATA(ls_match_changeable).

        lv_pattern = cl_dpr_co=>sc_note_text.
        FIND lv_pattern IN lv_note RESULTS DATA(ls_match_text).

        lv_offset          = ls_match_timestamp-offset + ls_match_timestamp-length.
        lv_length          = ls_match_creator-offset - lv_offset - 1.
        lv_timestamp_char  = lv_note+lv_offset(lv_length).

*     creator
        lv_offset = ls_match_creator-offset + ls_match_creator-length.
        lv_length = ls_match_changeable-offset - lv_offset - 1.
        lv_creator = lv_note+lv_offset(lv_length).


        lv_offset = ls_match_text-offset + ls_match_text-length.
        lv_length = strlen( lv_note ) - lv_offset - strlen( lc_end_of_note ) - 1.

        IF lv_length < 0.
          lv_length = 0.
        ENDIF.

        lv_text   = lv_note+lv_offset(lv_length).
        IF lv_text IS NOT INITIAL.
          CALL FUNCTION 'VB_CP_CONVERT_STRING_2_ITF'
            EXPORTING
              i_string = lv_text
            TABLES
              et_table = lt_tline.
        ENDIF.

*        SPLIT lv_text AT cl_abap_char_utilities=>newline INTO TABLE lt_note_ext.
*        CLEAR lv_text.
*
*        LOOP AT lt_note_ext INTO lv_note.
*          CONCATENATE lv_text lv_note INTO lv_text.
*        ENDLOOP.
        LOOP AT lt_tline INTO DATA(ls_line).
          APPEND ls_line-tdline TO et_line.
        ENDLOOP.
        ls_comment_ext-user_name = lv_creator.

*   Get full name of creator
        cl_aco_user=>get_instance(
          EXPORTING
            iv_id       = ls_comment_ext-user_name
          RECEIVING
            rr_instance = lr_user ).

        CALL METHOD lr_user->get_address
          RECEIVING
            rs_address    = lv_user_attributes
          EXCEPTIONS
            no_valid_user = 0.
        IF lv_user_attributes IS INITIAL.
          ls_comment_ext-full_name = ls_comment_ext-user_name.
        ELSE.
          ls_comment_ext-full_name = lv_user_attributes-fullname.
        ENDIF.

        CALL FUNCTION 'TZON_GET_USER_TIMEZONE'
          EXPORTING
            if_username             = ls_comment_ext-user_name
          IMPORTING
            ef_timezone             = lv_timezone
          EXCEPTIONS
            no_timezone_customizing = 1
            no_valid_user           = 2
            OTHERS                  = 3.
        IF sy-subrc IS NOT INITIAL.
          CALL FUNCTION 'GET_SYSTEM_TIMEZONE'
            IMPORTING
              timezone            = lv_timezone
            EXCEPTIONS
              customizing_missing = 1
              OTHERS              = 2.
          IF sy-subrc IS NOT INITIAL.
            lv_timezone = 'UTC+8'.
          ENDIF.
        ENDIF.
* add user's name and date/time stamp to comments
        lv_timestamp = lv_timestamp_char.
        WRITE lv_timestamp TIME ZONE lv_timezone TO lv_comment_header.
* concatenate comment header separated by space
        IF ls_comment_ext-full_name IS NOT INITIAL.
          CONCATENATE lv_comment_header
                      '-'
                      ls_comment_ext-full_name
                      INTO lv_comment_header
                      SEPARATED BY space.
        ENDIF.

        CONCATENATE lv_comment_header ls_separator INTO lv_comment_header.
        APPEND lv_comment_header TO et_line.

      ENDLOOP.

    ENDIF.
* get short text details passing format /=
    SELECT SINGLE * FROM /rpm/decision INTO @DATA(ls_decs)
                           WHERE guid = @iv_guid.
    IF sy-subrc IS INITIAL.
      SELECT SINGLE * FROM /rpm/item_d INTO @DATA(ls_item)
                         WHERE guid = @ls_decs-item_guid.
      IF sy-subrc IS INITIAL .
        CLEAR lt_lines.
        CALL METHOD cl_rpm_entity_services=>get_long_text_rpm
          EXPORTING
            iv_guid           = ls_item-guid
            iv_language       = iv_langu
            iv_format         = '/='
            iv_item_shorttext = abap_true
          IMPORTING
            et_lines          = lt_lines
            ev_string         = lv_string
          EXCEPTIONS
            invalid_language  = 1
            invalid_text_id   = 2
            not_found         = 3
            OTHERS            = 4.
        IF sy-subrc EQ 0 .
          ev_sh_text = lv_string.
        ENDIF.
      ENDIF.
    ENDIF.
  ENDMETHOD.
