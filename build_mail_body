FORM sub_pop_attachment USING pv_ref_task
                              p_lref_document TYPE REF TO cl_document_bcs.
  DATA: lt_attachment TYPE zhr_leave_doc_content_tt,
        ls_pakey      TYPE pakey,
        lt_contents   TYPE swftlisti1,
        lt_simp_cont  TYPE STANDARD TABLE OF swr_cont,
        lv_doc_type   TYPE so_obj_tp,
        lv_file_size  TYPE so_obj_len.

  IF pv_ref_task EQ 'TS90000443' OR pv_ref_task EQ 'TS90001338'.   "Mail comm during leave approval
    "'TS90000841': For cancela leave.
*   Get WF container for leave details
    CALL FUNCTION 'SAP_WAPI_READ_CONTAINER'
      EXPORTING
        workitem_id      = gv_top_wi_id
      TABLES
        simple_container = lt_simp_cont.
*   Get Key for HR Master Data
    READ TABLE lt_simp_cont INTO DATA(ls_simp_cont)
    WITH KEY element = 'ABSENCE'.
    IF sy-subrc EQ 0.
      "soc by c90005600 for wfh
      IF pv_ref_task EQ 'TS90001338'.
        READ TABLE lt_simp_cont INTO DATA(ls_index)
        WITH KEY element = 'INDEX'.
        IF ls_index-value = '1'.
          ls_pakey = ls_simp_cont-value+20(34).
*     Clear followinf fields as those are not required for attachment retrieval
          CLEAR: ls_pakey-objps, ls_pakey-sprps, ls_pakey-seqnr.
          CALL FUNCTION 'ZHR_GET_LEAVE_ATTACHMENT'
            EXPORTING
              im_pakey     = ls_pakey
            IMPORTING
              ev_doc_type  = lv_doc_type
              et_content   = lt_attachment
              ev_file_size = lv_file_size.
        ENDIF.
      ELSE.
     ls_pakey = ls_simp_cont-value+20(34).
*     Clear followinf fields as those are not required for attachment retrieval
        CLEAR: ls_pakey-objps, ls_pakey-sprps, ls_pakey-seqnr.
        CALL FUNCTION 'ZHR_GET_LEAVE_ATTACHMENT'
          EXPORTING
            im_pakey     = ls_pakey
          IMPORTING
            ev_doc_type  = lv_doc_type
            et_content   = lt_attachment
            ev_file_size = lv_file_size.
      ENDIF.
      IF lt_attachment[] IS NOT INITIAL.
*       Populate attachment in mail content
        LOOP AT lt_attachment INTO DATA(ls_attachment).
          TRY.
              p_lref_document->add_attachment(
              EXPORTING
                i_attachment_type    = ls_attachment-doc_type
                i_attachment_subject = ls_attachment-doc_name
                i_att_content_hex    = ls_attachment-content ).
            CATCH cx_document_bcs.
          ENDTRY.
        ENDLOOP.
      ENDIF.
    ENDIF.
  ENDIF.
ENDFORM.
