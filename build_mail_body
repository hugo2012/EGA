*&---------------------------------------------------------------------*
*&      Form  FRAME_MAIL_BODY
*&---------------------------------------------------------------------*
*  To frame the body part of the Email to be sent
*----------------------------------------------------------------------*
*  No interface parameters need to be passed to this subroutine
*----------------------------------------------------------------------*
FORM frame_mail_body.

  DATA: lv_text1 TYPE char255.

  PERFORM get_url.

*-- Font start
  PERFORM fill_lines1 USING '<FONT face=Arial size=2>'(040).
*-- FIRST LINE
  PERFORM fill_lines1 USING '<HTML><BODY>'.
*-- Word Please make a decision
  CLEAR: lv_text1.
  CONCATENATE 'Please Review and Approve/Reject Purchase Order'(016)
              gv_ebeln
         INTO lv_text1
    SEPARATED BY space.
  PERFORM fill_lines1 USING lv_text1.
*-- New line
  PERFORM fill_lines1 USING c_new_line.
  PERFORM fill_lines1 USING c_new_line.
*-- PO Details
  PERFORM fill_lines1 USING 'Details are:'(017).
*-- New line
  PERFORM fill_lines1 USING c_new_line.
*-- PO Details
  PERFORM fill_lines1 USING '----------------'.
*-- New line
  PERFORM fill_lines1 USING c_new_line.
  PERFORM fill_lines1 USING c_new_line.
*-- Vendor Dtls
  CLEAR: lv_text1.
  CONCATENATE 'Vendor code / Name                     :'(018)
              gv_lifnr
              '--'
              gv_name1
         INTO lv_text1
    SEPARATED BY ''.
  PERFORM fill_lines1 USING lv_text1.
*-- New line
  PERFORM fill_lines1 USING c_new_line.
*-- Buyer Dtls
  CLEAR: lv_text1.
  CONCATENATE 'Buyer code / Name                      :'(019)
              gv_ekgrp
              '--'
              gv_eknam
         INTO lv_text1
    SEPARATED BY ''.
  PERFORM fill_lines1 USING lv_text1.
*-- New line
  PERFORM fill_lines1 USING c_new_line.
*-- PO Currency
  CLEAR: lv_text1.
  CONCATENATE 'PO Currency                            :'(020)
              gv_waers
         INTO lv_text1
    SEPARATED BY ''.
  PERFORM fill_lines1 USING lv_text1.
*-- New line
  PERFORM fill_lines1 USING c_new_line.
*-- PO Amount
  CALL FUNCTION 'BAPI_CURRENCY_CONV_TO_EXTERNAL'
    EXPORTING
      currency        = gv_waers
      amount_internal = gv_poamt
    IMPORTING
      amount_external = gv_amtextr.

  WRITE gv_amtextr TO gv_poamtc DECIMALS 2.
  CONDENSE gv_poamtc NO-GAPS.

  CLEAR: lv_text1.
  CONCATENATE 'PO Amount                              :'(021)
              gv_poamtc
         INTO lv_text1
    SEPARATED BY '                              '.
  PERFORM fill_lines1 USING lv_text1.
*-- New line
  PERFORM fill_lines1 USING c_new_line.
*-- PO Amount Local Currency
  CLEAR: gv_amtextr.
  CALL FUNCTION 'BAPI_CURRENCY_CONV_TO_EXTERNAL'
    EXPORTING
      currency        = gv_waers
      amount_internal = gv_poamtlocl
    IMPORTING
      amount_external = gv_amtextr.

  WRITE gv_amtextr TO gv_poamtloclc  DECIMALS 2.
  CONDENSE gv_poamtloclc NO-GAPS.
  CLEAR: lv_text1.
  CONCATENATE 'PO Amount (In Local Currency)          :'(022)
              gv_poamtloclc
         INTO lv_text1
    SEPARATED BY '          '.
  PERFORM fill_lines1 USING lv_text1.

*-- New line
  PERFORM fill_lines1 USING c_new_line.
  PERFORM fill_lines1 USING c_new_line.
  PERFORM fill_lines1 USING c_new_line.
**-- New line
  PERFORM fill_lines1 USING c_new_line.

  PERFORM prepare_buttons USING lv_text1 ' '.
*-- New line
  PERFORM fill_lines1 USING c_new_line.
*-- New line
  PERFORM fill_lines1 USING c_new_line.
*-- SEVENTH line
  PERFORM fill_lines1 USING '</BODY></HTML>'.

*-- Subject of the Mail
  CONCATENATE 'DEMO: Please'(023)
              gv_aprvtext
              'Purchase Order :'(024)
              gv_ebeln        " 'Test Approval with Buttons for action in SAP'(008)
              gv_mailsubj
         INTO gv_mailsubj
    SEPARATED BY ''.

ENDFORM.                    " FRAME_MAIL_BODY


*&---------------------------------------------------------------------*
*& Form Name     : Send_mail                                           *
*&---------------------------------------------------------------------*
*& Description   : To set the recipients and send the mail             *
*&---------------------------------------------------------------------*
*& Parameters    : None                                                *
*&---------------------------------------------------------------------*
FORM send_mail USING pv_ref_task.

*-- Local data declaration for sending mail
  DATA: l_send_request  TYPE REF TO cl_bcs,
        l_document      TYPE REF TO cl_document_bcs,
        l_sender        TYPE REF TO cl_sapuser_bcs,
        l_sub           TYPE char50,
        l_recipient     TYPE REF TO if_recipient_bcs,
        lit_contents    TYPE STANDARD TABLE OF soli,
        l_doc_len       TYPE so_obj_len,
        l_cnt           TYPE sy-tabix,
        l_result        TYPE sy-binpt,
        l_subj          TYPE string,
        l_bcs_exception TYPE REF TO cx_bcs.

  DATA: lv_mail_address TYPE ad_smtpadr.
  DATA: lv_address      TYPE REF TO cl_cam_address_bcs.
  DATA: lv_addname      TYPE ad_smtpadr.
  TRY.
*-- Create persistent send request
      l_send_request = cl_bcs=>create_persistent( ).
      lit_contents[] = it_contents[].

*-- Get the length of the Document
      CLEAR: wa_contents.
      DESCRIBE TABLE lit_contents LINES l_cnt.
      READ TABLE lit_contents INTO wa_contents INDEX l_cnt.
      l_doc_len = ( l_cnt - 1 ) * 255 + strlen( wa_contents ).
*-- Subject of the mail
      l_sub = gv_mailsubj.
*<<< Modified by C90000111
      IF sy-sysid NE 'DSP'.
        CONCATENATE '**Test Message**:'
                    gv_mailsubj
               INTO l_subj.
      ELSE.
        l_subj = gv_mailsubj.
      ENDIF.
      l_sub = l_subj.
*>>> Modification end
*-- Create Document
      l_document = cl_document_bcs=>create_document(
                   i_type       = c_htm
                   i_text       = lit_contents
                   i_length     = l_doc_len
                   i_subject    = l_sub
                   i_language   = sy-langu
                   i_importance = '1' ).

*-- Subject of the mail
*      l_subj = gv_mailsubj.
      go_document = l_document.

      TRY.
*-- Set the Message Subject
          CALL METHOD l_send_request->set_message_subject
            EXPORTING
              ip_subject = l_subj.
        CATCH cx_sy_dyn_call_illegal_method.
      ENDTRY.

* Start of change DSDK967826:CRQ118763
*-- Populate attachment
      PERFORM sub_pop_attachment USING pv_ref_task
                                       l_document.
* End of change DSDK967826:CRQ118763

*-- Add document to send request
      CALL METHOD l_send_request->set_document( l_document ).

*-- Do send delivery info for successful mails
      CALL METHOD l_send_request->set_status_attributes
        EXPORTING
          i_requested_status = 'E'
          i_status_mail      = 'A'.
*<<<<  Modification related to CRQ11740
*      Fetch Domain mail
*     Approval mail will have sender name as per below matrix so approval can
*     easily categorize his/her pending items
      SELECT SINGLE unx_config FROM sopr INTO lv_mail_address.
      IF sy-subrc EQ 0.
        CONCATENATE 'WF-BATCH' lv_mail_address INTO lv_mail_address SEPARATED BY '@'.
        SELECT SINGLE sname FROM zutl_mob_switch INTO lv_addname
             WHERE objid EQ pv_ref_task+2(8).
        IF lv_addname IS INITIAL.
          lv_addname = 'Workflow System'(025).
        ENDIF.
*        CASE pv_ref_task.
*
*          WHEN 'TS90000431'. "Decision mail For Hedging Approval WF
*            lv_addname = 'Hedging Approval'.
*          WHEN 'TS90000432'. "Decision Mail for Petty Cash
*            lv_addname = 'PettyCash Approval'.
*          WHEN 'TS90000434' OR 'TS90000436'. "Decision mail for PO approval
*            lv_addname = 'PO Approval'.
*          WHEN 'TS90000435'. "Decision Mail for AR
*            lv_addname = 'AR Approval'.
*          WHEN 'TS90000437'. "Service Entry Sheet Decision by Mobile
*            lv_addname = 'SES Approval'.
*          WHEN 'TS90000438'. "Decision mail for PR approval
*            lv_addname = 'PR Approval'.
*          WHEN 'TS90000443'. "Decision via Email reg. absence approval
*            lv_addname = 'Leave Approval'.
*          WHEN OTHERS.
*            lv_addname = 'Workflow System'.
*        ENDCASE.
        TRY.
            CALL METHOD cl_cam_address_bcs=>create_internet_address
              EXPORTING
                i_address_string = lv_mail_address
                i_address_name   = lv_addname
*               i_incl_sapuser   =
              RECEIVING
                result           = lv_address.
          CATCH cx_address_bcs .
        ENDTRY.
      ENDIF.
*>>>  Modification end CRQ11740
*-- Set sender
*      l_sender = cl_sapuser_bcs=>create( sy-uname ).
      CALL METHOD l_send_request->set_sender
        EXPORTING
          i_sender = lv_address. "l_sender.

*-- Add the recipients to the Send mail
      CHECK NOT wa_poagents-emailid IS INITIAL.
      l_recipient = cl_cam_address_bcs=>create_internet_address(
                                                    wa_poagents-emailid ).
      CALL METHOD l_send_request->add_recipient
        EXPORTING
          i_recipient = l_recipient
          i_express   = 'X'.

*-- Send Email
      CALL METHOD l_send_request->send(
        EXPORTING
          i_with_error_screen = 'X'
        RECEIVING
          result              = l_result ).

      IF l_result = 'X'.
        CLEAR: gv_success.
      ELSE.
        gv_success = 'X'.
      ENDIF.

    CATCH cx_bcs INTO l_bcs_exception.
  ENDTRY.
  COMMIT WORK AND WAIT.                        "Commit Work

ENDFORM.                    " send_mail

