*&---------------------------------------------------------------------*
*&      Form  IDENTIFY_AGENTS_for_WI
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM identify_agents_for_wi USING p_status.

  DATA: it_wiid        TYPE swrtwiid,
        wa_wiid        TYPE swwwihead, " sww_wiid,
        lit_swwwihead  TYPE STANDARD TABLE OF swwwihead INITIAL SIZE 0,
        lit_swwwihead1 TYPE STANDARD TABLE OF swwwihead INITIAL SIZE 0,
        lv_subrc       TYPE sy-subrc,
        lv_timestamp   TYPE timestampl,
        lv_top_wi_id   TYPE swwwihead-wi_id,
        lwa_zswwwiauth TYPE zswwwiauth.

* First check whether the Approver is trying to re-approve already approved work item
  SELECT SINGLE *
    INTO lwa_zswwwiauth
    FROM zswwwiauth
   WHERE wi_id EQ gv_wiid.
  IF sy-subrc EQ 0 AND lwa_zswwwiauth-aedat IS NOT INITIAL AND
     lwa_zswwwiauth-actedby IS NOT INITIAL.
    gv_retcode = '90'.
    wa_message_lines-msg_type = 'E'.
    CONCATENATE 'Work Item already processed by'(038)
                lwa_zswwwiauth-actedby
           INTO wa_message_lines-line
      SEPARATED BY ''.
*   Work item has never been approved
  ELSE.
*   Get the top work item id
    SELECT SINGLE top_wi_id
           wi_rh_task
      INTO (lv_top_wi_id, gv_wirhtask)
      FROM swwwihead
     WHERE wi_id EQ gv_wiid.
    IF sy-subrc EQ 0.
      gv_top_wi_id = lv_top_wi_id.
      SELECT *
        INTO TABLE lit_swwwihead  " wa_wiid
        FROM swwwihead
       WHERE wi_type   EQ 'W'
*         AND wi_stat   EQ c_ready
         AND top_wi_id EQ lv_top_wi_id.
      IF sy-subrc EQ 0.
*<<<   Modification done by C90000111
*      Get actual approval of completed item and put it into
*      an internal table
        lit_swwwihead1[] = lit_swwwihead[].
        DELETE lit_swwwihead1 WHERE wi_stat NE 'COMPLETED'.
        LOOP AT lit_swwwihead1 INTO wa_wiid.
          MOVE wa_wiid-wi_aagent TO wa_capprover-wi_aagent.
          APPEND wa_capprover TO it_capprover.
        ENDLOOP.
        REFRESH: lit_swwwihead1.
*>>>   Modification end C90000111
        DELETE lit_swwwihead WHERE wi_stat EQ 'COMPLETED'
                                OR wi_stat EQ 'CANCELLED'.
        IF lit_swwwihead[] IS NOT INITIAL.
          READ TABLE lit_swwwihead INTO wa_wiid INDEX 1.
*<<<      Modification related to CRQ11740
*          IF wa_wiid-wi_stat EQ c_ready OR
*             ( ( wa_wiid-wi_stat EQ c_inprogress OR
*                 wa_wiid-wi_stat EQ c_reserved ) AND
*                wa_wiid-wi_aagent EQ gv_approver ).
