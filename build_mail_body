*&---------------------------------------------------------------------*
*&      Form  VALIDATE_APPROVER_WIID
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM validate_approver_wiid USING p_status.

  SORT it_agents BY user.
  SORT it_capprover BY wi_aagent.
  READ TABLE it_agents INTO wa_agents
                       WITH KEY user = gv_approver
                            BINARY SEARCH.
  IF sy-subrc EQ 0.
    CLEAR: gv_retcode.
  ELSE.
*<<< Modification done by C90000111
*    Check whether approver is aleardy actioned it. it valid for
*    worklow which having two level flow in same instance
*    For example: AR Workflow ( WS900000048)
*                 Leave Workflow (WS90000003)
    READ TABLE it_capprover INTO wa_capprover
                            WITH KEY wi_aagent = gv_approver
                                     BINARY SEARCH.
    IF sy-subrc EQ 0.
      gv_retcode = '97'.
      wa_message_lines-msg_type = 'E'.
      wa_message_lines-line = 'Work Item is not in Actionable State'(026).
    ELSE.
*>>> Modification related C90000111 CRQ11740.
*   If approver is having substitute so both would receive approval mail
*   and if any one open workitem and its would be disappeared from another
*   user inbox and this user want to approve it then he should get meaning
*   full message
*   The work item is not in Approver's Inbox - Approver not Geinue
      IF p_status EQ c_inprogress OR
         p_status EQ c_reserved   OR
         p_status EQ c_waiting.
        READ TABLE it_agents INTO wa_agents INDEX 1.
        IF sy-subrc EQ 0.
          gv_retcode = '97'.
          wa_message_lines-msg_type = 'E'.
          CONCATENATE 'The work item is already being processed by'(027)
                       wa_agents-user
                       '. Kindly wait for'(028)
                       wa_agents-user
                       'to finish processing the item or, if required,'(029)
                       'contact IT to redirect the work item'(030) INTO wa_message_lines-line.
*      wa_message_lines-line = 'Invalid Approver'.
        ELSE.
          gv_retcode = '97'.
          wa_message_lines-msg_type = 'E'.
          wa_message_lines-line = 'Invalid Approver'(031).
        ENDIF.
*>>>  End of modification CRQ11740
      ELSE.
        gv_retcode = '97'.
        wa_message_lines-msg_type = 'E'.
        wa_message_lines-line = 'Invalid Approver'(031).
      ENDIF.
    ENDIF.
  ENDIF.

ENDFORM.                    " VALIDATE_APPROVER_WIID


