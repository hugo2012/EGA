FORM release_pr .

  DATA:  lv_bnfpo         TYPE bnfpo,
         lv_banfn         TYPE banfn,
         lv_relcode       TYPE rm06b-form1,
         e_return         TYPE char1,
         e_message        TYPE text120,
         lwa_wi_container TYPE swcont,
         lit_wi_container TYPE STANDARD TABLE OF swcont INITIAL SIZE 0.

* Read containers values for the work item to get the employee number
  CALL FUNCTION 'SWW_WI_CONTAINER_READ'
    EXPORTING
      wi_id                    = gv_wiid
    TABLES
      wi_container             = lit_wi_container
    EXCEPTIONS
      container_does_not_exist = 1
      read_failed              = 2
      OTHERS                   = 3.
  IF sy-subrc <> 0.
*   MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*         WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
  ELSE.
*   PR Number
    READ TABLE lit_wi_container INTO lwa_wi_container
                        WITH KEY element = 'BANFN'.
    IF sy-subrc EQ 0.
      lv_banfn = lwa_wi_container-value.
    ENDIF.

*   PR Item
    READ TABLE lit_wi_container INTO lwa_wi_container
                        WITH KEY element = 'BNFPO'.
    IF sy-subrc EQ 0.
      lv_bnfpo    = lwa_wi_container-value.
    ENDIF.

*   Release Code
    READ TABLE lit_wi_container INTO lwa_wi_container
                        WITH KEY element = 'RELCODE'.
    IF sy-subrc EQ 0.
      lv_relcode = lwa_wi_container-value.
    ENDIF.

    IF lv_banfn IS NOT INITIAL AND lv_bnfpo IS NOT INITIAL AND lv_relcode IS NOT INITIAL.
*     "Modification related to CRQ129173
*     " In Case of lock, Capture the whole message to check whether PR Item is
*     "enquest or not
*     "CHeck Lock
      CALL FUNCTION 'ENQUEUE_EMEBANE'
        EXPORTING
          banfn          = lv_banfn
          bnfpo          = lv_bnfpo
        EXCEPTIONS
          foreign_lock   = 1
          system_failure = 2
          OTHERS         = 3.
      IF sy-subrc <> 0.
*       "Implement suitable error handling here
        TRY.
            MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
                    WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4
                    INTO wa_message_lines-line.

            gv_retcode = '81'.
            wa_message_lines-msg_type = 'E'.
          CATCH cx_root.
            gv_retcode = '81'.
            wa_message_lines-msg_type = 'E'.
            wa_message_lines-line = 'Error occured while locking the object'.
        ENDTRY.
*        MESSAGE s000(26) WITH e_message INTO wa_message_lines-line.
      ELSE.
        CALL FUNCTION 'DEQUEUE_EMEBANE'
          EXPORTING
            banfn = lv_banfn
            bnfpo = lv_bnfpo.
*     "Modification end CRQ129173

        CALL FUNCTION 'ZMM_PR_RELEASE_BAPI'
          EXPORTING
            i_banfn              = lv_banfn
            i_bnfpo              = lv_bnfpo
            i_relcode            = lv_relcode
          IMPORTING
            e_return             = e_return
            e_message            = e_message
          EXCEPTIONS
            authority_check_fail = 1
            enqueue_fail         = 2
            OTHERS               = 3.
        IF e_return EQ 'X'.
          gv_retcode = '81'.
          wa_message_lines-msg_type = 'E'.
          MESSAGE s000(26) WITH e_message INTO wa_message_lines-line.
        ENDIF.
      ENDIF.
    ELSE.
      gv_retcode = '80'.
      wa_message_lines-msg_type = 'E'.
      wa_message_lines-line = |Data missing { lv_banfn } { lv_bnfpo } { lv_relcode }|.
    ENDIF.
  ENDIF.
ENDFORM.
