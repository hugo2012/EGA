*&---------------------------------------------------------------------*
*&      Form  CONVERT_TLINES
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM convert_tlines USING p_ref_task.

  DATA: lv_flag          TYPE char3,
        lv_cntr1         TYPE sy-tabix,
        lv_details_desc  TYPE char100,
        lv_details_value TYPE char100,
        lv_position      TYPE string,
        lv_username      TYPE string,
        lv_userid        TYPE string,
        lv_str1          TYPE string,
        lv_str2          TYPE string,
        lv_str3          TYPE string,
        lv_number        TYPE char10,
        lv_item          TYPE char5,
        lv_tdobject      TYPE thead-tdobject,
        lv_tdid          TYPE thead-tdid,
        lv_tdname        TYPE thead-tdname,
        lv_tdtext        TYPE thead-tdname,
        lv_bl00          TYPE c. " Business leave indicator CHG1365


*<<< Modification related to CRQ25212 by C90001174
* This modification is to show all the plan values
* in the approval email.
  DATA lwa_plan_val TYPE zfi_planning_values.
*>>> End of modification.

  CONSTANTS:
        con_tab  TYPE c VALUE cl_abap_char_utilities=>horizontal_tab.

  LOOP AT it_lines INTO wa_lines.
    CASE wa_lines-tdline.
*<<< Modification related to CRQ25212 by C90001174
* This modification is to show all the plan values
* in the approval email.
*      WHEN 'Header' OR 'Details' OR 'Footer' OR 'Buttons' OR
*           'AR' OR 'AR1' OR 'HN1' OR 'HN2' OR 'IN1' OR 'IN2' OR
*           'IN3' OR 'Error' OR 'Additional'.
      WHEN 'Header' OR 'Details' OR 'Footer' OR 'Buttons' OR
           'AR' OR 'AR1' OR 'HN1' OR 'HN2' OR 'IN1' OR 'IN2' OR
           'IN3' OR 'Error' OR 'Additional' OR 'PV' OR 'PPM'. "CRQ122651:E0008.
*>>> End of modification
        CLEAR: lv_flag.
* Begin Add C120032 CHG1365
        IF wa_key-subty(2) = 'BL' AND wa_key IS NOT INITIAL.
          IF lv_flag NE lv_bl00 AND lv_bl00 = 'H'.
            CLEAR wa_header.
            APPEND INITIAL LINE TO it_header.
            wa_header-tdline = 'Event Title & Description:'.
            APPEND wa_header TO it_header.
            CLEAR: wa_header,lv_bl00.
            APPEND INITIAL LINE TO it_header.
            LOOP AT it_text INTO DATA(wa_text).
              wa_header-tdline = wa_text-textline.
              APPEND wa_header TO it_header.
              CLEAR: wa_header.
            ENDLOOP.
          ENDIF.
        ENDIF.
* End Add C120032 CHG1365
* Begin Add C90005867
        IF wa_key-subty(4) = 'WR13' AND wa_key IS NOT INITIAL.
          IF lv_flag NE lv_bl00 AND lv_bl00 = 'W'.
            CLEAR wa_header.
            APPEND INITIAL LINE TO it_header.
            wa_header-tdline = 'Country Travelling To:'.
            APPEND wa_header TO it_header.
            CLEAR: wa_header,lv_bl00.
            APPEND INITIAL LINE TO it_header.
            LOOP AT it_text INTO DATA(wa_text1).
              wa_header-tdline = wa_text1-textline.
              APPEND wa_header TO it_header.
              CLEAR: wa_header.
            ENDLOOP.
          ENDIF.
        ENDIF.
* End Add C90005867

      WHEN OTHERS.
    ENDCASE.
    IF lv_flag EQ 'H'.
*      IF gv_header IS INITIAL.
*        gv_header = wa_lines-tdline.
*      ELSE.
*        CONCATENATE gv_header
*                    wa_lines-tdline
*               INTO gv_header
*           SEPARATED BY ''.
*      ENDIF.
      wa_header-tdline = wa_lines-tdline.
      APPEND wa_header TO it_header.
      CLEAR: wa_header.
    ELSEIF lv_flag EQ 'D'.
      SPLIT wa_lines-tdline
          AT ':'
        INTO lv_details_desc
             lv_details_value.
*<<<  Modification related to PO Mobile Approval
*     Business want to see all details whethere its having values or not
      IF p_ref_task EQ 'TS90000436'.
        IF NOT lv_details_desc IS INITIAL.
          CONCATENATE lv_details_desc
                       ':'
                  INTO wa_mailbody-details_desc.
          wa_mailbody-details_value = lv_details_value.
          APPEND wa_mailbody TO it_mailbody.
          CLEAR: wa_mailbody.
        ENDIF.
      ELSE.
        IF NOT lv_details_desc IS INITIAL AND
           NOT lv_details_value IS INITIAL.
          CONCATENATE lv_details_desc
                      ':'
                 INTO wa_mailbody-details_desc.
          wa_mailbody-details_value = lv_details_value.
          APPEND wa_mailbody TO it_mailbody.
          CLEAR: wa_mailbody.
        ENDIF.
      ENDIF.
*>>>  Modification end
    ELSEIF lv_flag EQ 'F'.
      IF gv_footer IS INITIAL.
        gv_footer = wa_lines-tdline.
      ELSE.
        CONCATENATE gv_footer
                    wa_lines-tdline
               INTO gv_footer
           SEPARATED BY ''.
      ENDIF.
    ELSEIF lv_flag EQ 'B'.
      TRY.
*        BREAK C90000111.
          IF wa_lines-tdline CA ':'.
            SPLIT wa_lines-tdline AT ':' INTO wa_buttons-name wa_buttons-deckey.
            IF wa_buttons-deckey CO '0123456789' AND wa_buttons-deckey IS NOT INITIAL.
            ELSE.
              wa_buttons-name = wa_lines-tdline.
            ENDIF.
          ELSE.
            wa_buttons-name = wa_lines-tdline.
          ENDIF.
        CATCH cx_root.
          wa_buttons-name = wa_lines-tdline.
      ENDTRY.
      APPEND wa_buttons TO it_buttons.
      CLEAR: wa_buttons.
    ELSEIF lv_flag EQ 'A'.
      APPEND wa_lines TO it_lines1.
      CLEAR: wa_lines.
      APPEND wa_lines TO it_lines1.
    ELSEIF lv_flag EQ 'R'.
      lv_cntr1 = lv_cntr1 + 1.
      IF lv_cntr1 EQ 1.
        IF wa_lines-tdline IS NOT INITIAL.
          CLEAR: lv_userid, lv_username, lv_position,
                 lv_str1, lv_str2.


          SPLIT wa_lines-tdline AT 'DUB' INTO lv_str1 lv_str2.
          IF lv_str1 EQ wa_lines-tdline.
            SPLIT wa_lines-tdline AT 'C90' INTO lv_str1 lv_str2.
            IF lv_str1 EQ wa_lines-tdline.
*               For Others Users
              CLEAR : lv_str1,lv_str2.
              PERFORM get_strings USING wa_lines-tdline
                                        lv_str1
                                        lv_str2
                                        lv_userid
                                        lv_username.


            ELSE.
              CONCATENATE 'C90'
                          lv_str2
                     INTO lv_str2.
            ENDIF.
          ELSE.
            CONCATENATE 'DUB'
                        lv_str2
                   INTO lv_str2.
          ENDIF.
*<<<      Modification related to CRQ16089
          IF lv_str2 IS NOT INITIAL.
*>>>      Modification end CRQ16089
            lv_userid = lv_str2+0(9).
            lv_username = lv_str2+10.
*<<<      Modification related to CRQ16089
          ENDIF.
*>>>      Modification end CRQXXX
          lv_position = lv_str1.
          CONDENSE: lv_userid, lv_username, lv_position.
          CONCATENATE lv_position
                      ':'
                 INTO lv_position.
          CONCATENATE '('
                      lv_userid
                      ')'
                 INTO lv_userid.
          CONCATENATE lv_username
                      lv_userid
                 INTO lv_username
            SEPARATED BY ''.
          CONCATENATE lv_position
                      lv_username
                 INTO wa_arstatus-details_desc
            SEPARATED BY '        '
            RESPECTING BLANKS.
        ENDIF.
*        wa_arstatus-details_desc = wa_lines-tdline.
      ELSE.
        wa_arstatus-details_value = wa_lines-tdline.
        APPEND wa_arstatus TO it_arstatus.
        CLEAR: wa_arstatus.
        lv_cntr1 = 0.
      ENDIF.
    ELSEIF lv_flag EQ 'HN1'.
      CLEAR: lv_tdname, gv_hn1text.
      SPLIT wa_lines-tdline AT '/'
       INTO lv_tdobject lv_tdid lv_number gv_hn1text.
      PERFORM apply_conversion_exits USING lv_number
                                           lv_item.
      lv_tdname = lv_number.
      PERFORM read_text TABLES it_hn1
                        USING lv_tdobject
                              lv_tdid
                              lv_tdname.
    ELSEIF lv_flag EQ 'HN2'.
      IF wa_lines-tdline IS NOT INITIAL.
        CLEAR: lv_tdname, gv_hn2text.
        SPLIT wa_lines-tdline AT '/'
         INTO lv_tdobject lv_tdid lv_number gv_hn2text.
      ENDIF.
*      SPLIT wa_lines-tdline AT '/'
*       INTO lv_tdobject lv_tdid lv_number gv_hn2text.
      PERFORM apply_conversion_exits USING lv_number
                                           lv_item.
      lv_tdname = lv_number.
      PERFORM read_text TABLES it_hn2
                        USING lv_tdobject
                              lv_tdid
                              lv_tdname.

    ELSEIF lv_flag EQ 'IN1'.
      CLEAR: lv_tdname, gv_in1text.
      SPLIT wa_lines-tdline AT '/'
       INTO lv_tdobject lv_tdid
            lv_number lv_item gv_in1text.
      PERFORM apply_conversion_exits USING lv_number
                                           lv_item.
      CONCATENATE lv_number
                  lv_item
             INTO lv_tdname.
      PERFORM read_text TABLES it_in1
                        USING lv_tdobject
                              lv_tdid
                              lv_tdname.
    ELSEIF lv_flag EQ 'IN2'.
      CLEAR: lv_tdname.
      SPLIT wa_lines-tdline AT '/'
       INTO lv_tdobject lv_tdid
            lv_number lv_item gv_in2text.
      PERFORM apply_conversion_exits USING lv_number
                                           lv_item.
      CONCATENATE lv_number
                  lv_item
             INTO lv_tdname.
      PERFORM read_text TABLES it_in2
                        USING lv_tdobject
                              lv_tdid
                              lv_tdname.
    ELSEIF lv_flag EQ 'IN3'.
      CLEAR: lv_tdname.
      SPLIT wa_lines-tdline AT '/'
       INTO lv_tdobject lv_tdid
            lv_number lv_item gv_in3text.
      PERFORM apply_conversion_exits USING lv_number
                                           lv_item.
      CONCATENATE lv_number
                  lv_item
             INTO lv_tdname.
      PERFORM read_text TABLES it_in3
                        USING lv_tdobject
                              lv_tdid
                              lv_tdname.
    ELSEIF lv_flag EQ 'E'.
*      IF gv_error IS INITIAL.
*        gv_error = wa_lines-tdline.
*      ELSE.
*        CONCATENATE gv_error
*                    wa_lines-tdline
*               INTO gv_error
*           SEPARATED BY ''.
*      ENDIF.
      wa_error-tdline = wa_lines-tdline.
      APPEND wa_error TO it_error.
      CLEAR: wa_error.

    ELSEIF lv_flag EQ 'AD'.
      wa_additional-tdline = wa_lines-tdline.
      APPEND wa_additional TO it_additional.
      CLEAR: wa_additional.
*<<< Modification related to CRQ25212 by C90001174
* This modification is to show all the plan values
* in the approval email.
    ELSEIF lv_flag EQ 'P'.

      IF NOT wa_lines-tdline+0(13) IS INITIAL AND
         NOT wa_lines-tdline+14(25) IS INITIAL.
        lwa_plan_val-gjahr = wa_lines-tdline+0(13).
        lwa_plan_val-wtjhr = wa_lines-tdline+14(25).
        APPEND lwa_plan_val TO it_plan_val.
        CLEAR: lwa_plan_val.
      ENDIF.
* End of modification
      "-CRQ122651:E0008 begin
    ELSEIF lv_flag EQ 'PPM'.
      wa_ppm-tdline = wa_lines-tdline.
      APPEND wa_ppm TO it_ppm.
      CLEAR: wa_ppm.
      "-CRQ122651:E0008 end
    ENDIF.
    CASE wa_lines-tdline.
      WHEN 'Header'.
        lv_flag = 'H'.
        lv_bl00 = 'H'." Business leave indicator.
        if wa_key-subty(4) = 'WR13'.
          lv_bl00 = 'W'. " WFH overseas leave indicator.
        endif.
      WHEN 'Details'.
        lv_flag = 'D'.
      WHEN 'Footer'.
        lv_flag = 'F'.
      WHEN 'Buttons'.
        lv_flag = 'B'.
      WHEN 'AR'.
        lv_flag = 'A'.
        gv_arflag = 'X'.
      WHEN 'AR1'.
        lv_flag = 'R'.
        gv_arflag = 'X'.
      WHEN 'HN1'.
        lv_flag = 'HN1'.
      WHEN 'HN2'.
        lv_flag = 'HN2'.
      WHEN 'IN1'.
        lv_flag = 'IN1'.
      WHEN 'IN2'.
        lv_flag = 'IN2'.
      WHEN 'IN3'.
        lv_flag = 'IN3'.
      WHEN 'Error'.
        lv_flag = 'E'.
      WHEN 'Additional'.
        lv_flag = 'AD'.
*<<< Modification related to CRQ25212 by C90001174
* This modification is to show all the plan values
* in the approval email.
      WHEN 'PV'.
        lv_flag = 'P'.
* End of modification.
      WHEN 'PPM'.
        lv_flag = 'PPM'.
      WHEN OTHERS.
    ENDCASE.
    CLEAR: wa_lines.
  ENDLOOP.

ENDFORM.                    " CONVERT_TLINES


*&---------------------------------------------------------------------*
*&      Form  CONVERT_INTO_RTF
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM convert_into_rtf.

  DATA: lf_formname           TYPE tdsfname.
  DATA: lf_fm_name            TYPE rs38l_fnam.

  DATA: output_options     TYPE ssfcompop,
        xsfparam_line      TYPE ssfxsfp,
        control_parameters TYPE ssfctrlop,
        output_data        TYPE ssfcrescl,
        fm_name            TYPE rs38l_fnam.

* silent mode ON
  output_options-tdimmed = space.
  output_options-tdnewid = space.
  control_parameters-no_dialog = 'X'.
  control_parameters-getotf = 'X'.

* determine smartform function module for invoice
  CALL FUNCTION 'SSF_FUNCTION_MODULE_NAME'
    EXPORTING
      formname           = 'ZUTL_WF_EMAIL'
    IMPORTING
      fm_name            = lf_fm_name
    EXCEPTIONS
      no_form            = 1
      no_function_module = 2
      OTHERS             = 3.
  IF sy-subrc <> 0.
*   error handling
    MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
            WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.
    EXIT.
  ELSE.
    CALL FUNCTION lf_fm_name
      EXPORTING
        control_parameters = control_parameters
        output_options     = output_options
        user_settings      = space
        header             = gv_header
        footer             = gv_footer
      IMPORTING
        job_output_info    = output_data
      TABLES
        details            = it_mailbody
      EXCEPTIONS
        formatting_error   = 1
        internal_error     = 2
        send_error         = 3
        user_canceled      = 4
        OTHERS             = 5.
    IF sy-subrc <> 0.
*   error handling
      MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
              WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.
      EXIT.
    ELSE.
      it_otf = output_data-otfdata.
      PERFORM mailtxt_otf.
    ENDIF.
  ENDIF.

ENDFORM.                    " CONVERT_INTO_RTF


