*&---------------------------------------------------------------------*
*&      Form  WRITE_TO_CONTAINER
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM write_to_container.

  DATA: lwa_swwwihead TYPE swwwihead,
        lv_so_obj_des TYPE so_obj_des.

  wa_swr_cont-element = 'RFCAPPROVER'.
  CONCATENATE 'US'
              gv_approver
         INTO wa_swr_cont-value.
  APPEND wa_swr_cont TO it_swr_cont.

  wa_swr_cont-element = 'RFC'.
  wa_swr_cont-value   = 'X'.
  APPEND wa_swr_cont TO it_swr_cont.

  CALL FUNCTION 'SAP_WAPI_WRITE_CONTAINER'
    EXPORTING
      workitem_id      = gv_top_wi_id
      actual_agent     = gv_approver
      do_commit        = 'X'
    IMPORTING
      return_code      = gv_retcode1
    TABLES
      simple_container = it_swr_cont.

* If reasons for rejection are there and work item has been rejected
* then create an SOFM object with the notes given in
  IF gv_rejreason IS NOT INITIAL.
*   From the string convert it into internal table for SOFM Object creation
    CALL FUNCTION 'RKD_WORD_WRAP'
      EXPORTING
        textline            = gv_rejreason
        outputlen           = c_255
      TABLES
        out_lines           = it_note_text
      EXCEPTIONS
        outputlen_too_large = 1
        OTHERS              = 2.
    IF sy-subrc <> 0.
*     MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*         WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
    ENDIF.

*   Get the subject line for the object attachment
    SELECT SINGLE *
      INTO lwa_swwwihead
      FROM swwwihead
     WHERE wi_id EQ gv_top_wi_id.
    IF sy-subrc EQ 0.
      lv_so_obj_des = lwa_swwwihead-wi_text+0(50).
    ELSE.
      lv_so_obj_des = 'Rejection Reasons'(033).
    ENDIF.
* Create object
    CALL FUNCTION 'SWL_SOFM_CREATE_WITH_TABLE'
      EXPORTING
        note_title          = lv_so_obj_des
        document_type       = 'RAW'
      IMPORTING
        sofm_key            = gv_sofm_key
      TABLES
        note_text           = it_note_text
      EXCEPTIONS
        error_sofm_creation = 1
        OTHERS              = 2.
    IF sy-subrc <> 0.
      gv_retcode = '94'.
      wa_message_lines-msg_type = 'E'.
      wa_message_lines-line
          = 'Error creating object for Rejection Reasons'(034).
    ELSE.
      wa_note = gv_sofm_key.
*   Attach the object created above to work item
      CALL FUNCTION 'SWL_WI_NOTE_CREATE'
        EXPORTING
          wi_id                         = wa_swwwihead-wi_id
          note                          = wa_note
          do_commit                     = 'X'
        CHANGING
          wi_header                     = wa_wiheader
        EXCEPTIONS
          error_setting_note_exist_flag = 1
          error_note_creation           = 2
          error_container_update        = 3
          container_does_not_exist      = 4
          error_in_wi_enqueue           = 5
          illegal_wi_state              = 6
          wi_header_read_failed         = 7
          object_creation_failed        = 8
          method_calling_failed         = 9
          wi_buffer_refresh_failed      = 10
