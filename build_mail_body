*&---------------------------------------------------------------------*
*&      Form  FILL_LINES2
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_TEXT1  First  Line
*      -->P_TEXT2  Second Line
*      -->P_TEXT3  Third  Line
*      -->P_TEXT4  Fourth Line
*      -->P_NOS    No of Spaces
*----------------------------------------------------------------------*
FORM fill_lines2 USING p_text1 TYPE char255
                       p_text2 TYPE char255
                       p_text3 TYPE char255
                       p_text4 TYPE char255
                       p_nos   TYPE char2.

  DATA: lv_str TYPE string.

  CLEAR wa_contents.
  IF p_nos IS INITIAL.
    CONCATENATE p_text1 p_text2
                p_text3 p_text4
           INTO wa_contents-line
      SEPARATED BY ''.
  ELSE.
    DO p_nos TIMES.
      CONCATENATE lv_str c_space
             INTO lv_str
        SEPARATED BY ''.
    ENDDO.

    CONCATENATE p_text1 p_text2
                p_text3 p_text4
                lv_str
           INTO wa_contents-line
      SEPARATED BY ''.
  ENDIF.
  APPEND wa_contents TO it_contents.

ENDFORM.                    " FILL_LINES2


