*&      Form  GET_STATUS_DATE_PARTNER
*&---------------------------------------------------------------------*
*    to extract status,date & partner & add as  column into html table
*----------------------------------------------------------------------*
*----------------------------------------------------------------------*
FORM get_status_date_partner USING wa_arstatus TYPE zsd_s_mailbody
                                   lv_text1 TYPE char255.

  DATA:      lv_part1              TYPE c LENGTH 15,
             lv_part2              TYPE c LENGTH 15,
             lv_part3              TYPE c LENGTH 15,
             lv_status_date        TYPE c LENGTH 25,
             lv_partner_type       TYPE c LENGTH 25,
             lv_partner_type_blank TYPE c LENGTH 25 VALUE '',
* <<< Begin of Addition : CRQ26290 - DSDK942706 by C9000286 >>>
* Variable declaration to accommodate approval text
             lv_part4              TYPE c LENGTH 15,
             lv_part5              TYPE c LENGTH 15,
             lv_part6              TYPE c LENGTH 15,
             lv_approved_by        TYPE c LENGTH 50,
             lv_col_count          TYPE i,
             lv_user_id            TYPE xubname,
             lv_user_name          TYPE ad_namtext.
* <<< End of Addition : CRQ26290 - DSDK942706 by C9000286 >>>

  DATA : BEGIN OF lv_itab OCCURS 0,
           txt TYPE c LENGTH 15,
         END OF lv_itab,
         wa_lv_itab LIKE LINE OF lv_itab.

* Cases Handle here

* 1) When both role is missing and Approved by string was wrongly concatenated
*    Manager: Mr.XYZ (DUB0000) Approved 16.09.2014  Approved
* 2) When both role is missing
*   Manager: Mr.XYZ (DUB0000) Approved 16.09.2014            Approved by C90001183
* 3) When both role is avaialbe but approved by string was wrongly concatenated
*   Manager: Mr.XYZ (DUB0000) Approved 16.09.2014  INTIATOR  Approved by


  "Splitting string to diffrentiate between status , date and partner type
  SPLIT wa_arstatus-details_value AT ' '
     INTO TABLE lv_itab.
  DELETE lv_itab WHERE txt EQ ' '.
  LOOP AT lv_itab INTO wa_lv_itab .
    CASE sy-tabix.
      WHEN 1.
        lv_part1 = wa_lv_itab-txt.
      WHEN 2.
        lv_part2 = wa_lv_itab-txt.
      WHEN 3.
        lv_part3 = wa_lv_itab-txt.
      WHEN 4.                                               " CRQ26290
        lv_part4 = wa_lv_itab-txt.
      WHEN 5.                                               " CRQ26290
        lv_part5 = wa_lv_itab-txt.
      WHEN 6.                                               " CRQ26290
        lv_part6 = wa_lv_itab-txt.
      WHEN OTHERS.

    ENDCASE.
  ENDLOOP.

* <<< Begin of Addition : CRQ26290 - DSDK942706 by C9000286 >>>
* Count the No of lines from workflow log for this activity
  DESCRIBE TABLE lv_itab LINES lv_col_count.
* If line count is 6
  IF lv_col_count EQ 6.
* Join text from varaibles containning values of User ID and approval text
    CONCATENATE lv_part4 lv_part5 lv_part6 INTO lv_approved_by SEPARATED BY space.
* Set the value of user id in a local varaible to be used to get the name of user from master record
    lv_user_id = lv_part6.
* If line count is 5
  ELSEIF lv_col_count EQ 5.
* Join text from varaibles containning Action and User ID
    CONCATENATE lv_part3 lv_part4 lv_part5 INTO lv_approved_by SEPARATED BY space.
* Set the value of user id in a local varaible to be used to get the name of user from master record
    lv_user_id = lv_part5.
  ENDIF.
* <<< End of Addition : CRQ26290 - DSDK942706 by C9000286 >>>

  "Specifies that the 2nd part of the string is date
  IF lv_part2 CA '.'.
    CONCATENATE lv_part1 lv_part2
    INTO lv_status_date SEPARATED BY space.
* Check for the correct role of the approver incase of reject reapproval
* If the approve by user id and Role is not avaialble then only allow to map the value
    IF ( lv_col_count NE 4 AND lv_col_count NE 5 ).
      lv_partner_type = lv_part3.
    ENDIF.
    CONDENSE:  lv_status_date,lv_partner_type.
    "Specifies that the 2nd part of the string is partner type
  ELSE.
    lv_status_date  = lv_part1.
    lv_partner_type = lv_part2.
    CONDENSE:  lv_status_date,lv_partner_type.
  ENDIF.

*Addiing the columns
*Status & Date
  CONCATENATE '<td>' '<p><code>'
              lv_status_date '</p></code>' '</td>'
         INTO lv_text1.
  PERFORM fill_lines1 USING lv_text1.
  CLEAR: lv_text1.

*Partnet Type
  IF lv_partner_type IS NOT INITIAL.
    CONCATENATE '<td width="10%">' '<p><code>'
                lv_partner_type '</p></code>' '</td>'
           INTO lv_text1.
    PERFORM fill_lines1 USING lv_text1.
    CLEAR: lv_text1.
  ELSE.
    lv_text1 =  '<td width="10%">&nbsp;</td>'.

    PERFORM fill_lines1 USING lv_text1.
    CLEAR: lv_text1.
  ENDIF.

* <<< Begin of Addition : CRQ26290 - DSDK942706 by C9000286 >>>
*Approve by
* Check if approved by text was filled
  IF lv_approved_by IS NOT INITIAL.

* Call a subroutine to get the user name from master record
    PERFORM get_user_name
    USING lv_user_id
    CHANGING lv_user_name.

* Concatenate the user name with the uer id
    CONCATENATE lv_approved_by ' (' lv_user_name ')'
    INTO lv_approved_by.

* Creat Table column to display approve by text
    CONCATENATE '<td width="40%">' '<p><code>'
                lv_approved_by '</p></code>' '</td>'
           INTO lv_text1.
    PERFORM fill_lines1 USING lv_text1.
    CLEAR: lv_text1.
  ELSE.
* If Approve by text is not filled then creat table column with no value for formatting purpose
    lv_text1 =  '<td width="40%">&nbsp;</td>'.
    PERFORM fill_lines1 USING lv_text1.
    CLEAR: lv_text1.
  ENDIF.
* <<< End of Addition : CRQ26290 - DSDK942706 by C9000286 >>>

  CLEAR: lv_status_date,lv_partner_type,
         lv_part1,lv_part2,lv_part3,
         lv_part4,lv_part5,lv_part6,
         lv_approved_by , lv_col_count,
         lv_user_id.

ENDFORM.                    " GET_STATUS_DATE_PARTNER
